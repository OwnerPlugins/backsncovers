msgid "TMDb series results, %s %s for %s"
msgstr "TMDb ශ්‍රේණි ප්‍රතිඵල, %s සඳහා %s %s"

msgid "backsNcovers"
msgstr ""

msgid "virtual folder not possible!"
msgstr "අතථ්‍ය ෆෝල්ඩරය කළ නොහැක!"
